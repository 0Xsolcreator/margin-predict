# Backend base URL (the server-custodial API). Default http://localhost:3000.
REACT_APP_API_URL=http://localhost:3000

# Google OAuth client ID — used by Google Identity Services to issue the
# nonce-bound id_token the backend trades for a session (POST /auth/finish).
# Must be authorized for this app's origin in Google Cloud Console.
REACT_APP_GOOGLE_CLIENT_ID=
