# Keeper wallet (must own PREDICT_MANAGER_ID and MARGIN_MANAGER_ID)
# Export via: sui keytool export --key-identity <your-address>
SUI_PRIVATE_KEY=suiprivkey...

# Network: testnet | mainnet (default: testnet)
NETWORK=testnet

# Server port (default: 4000)
KEEPER_PORT=4000

# margin_predict package — set after publishing contracts/margin_predict/
MARGIN_PREDICT_PACKAGE=0x...

# Shared PredictManager — create via DeepBook Predict CLI
PREDICT_MANAGER_ID=0x...

# Shared SUI/DBUSDC MarginManager — create via DeepBook Margin setup
MARGIN_MANAGER_ID=0x...

# DUSDC/DBUSDC swap pool — create via DeepBook pool creation scripts
DUSDC_DBUSDC_POOL_ID=0x...

# Swap configuration
SWAP_SLIPPAGE_BPS=100
SWAP_DEEP_AMOUNT=0

# Fallback SUI/USD price for sizing borrows when Pyth Hermes is unreachable
SUI_PRICE_ESTIMATE=1.5
