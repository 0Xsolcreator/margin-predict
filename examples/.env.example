# ── User wallet ───────────────────────────────────────────────────────────────
# The user signing request_open / request_close (NOT the keeper wallet).
# Export via: sui keytool export --key-identity <your-address>
USER_PRIVATE_KEY=suiprivkey...

# ── Network ────────────────────────────────────────────────────────────────────
NETWORK=testnet
# Optional: override the default Sui fullnode URL
# RPC_URL=https://fullnode.testnet.sui.io:443

# ── Keeper service ─────────────────────────────────────────────────────────────
KEEPER_URL=http://localhost:4000

# ── Deployed contract IDs ──────────────────────────────────────────────────────
# Published margin_predict package address
MARGIN_PREDICT_PACKAGE=0x...

# PredictManager shared object owned by the keeper (same value as keeper/.env)
PREDICT_MANAGER_ID=0x...

# ── Prediction market (oracle) parameters ──────────────────────────────────────
# The OracleSVI shared object for the market you want to trade
ORACLE_ID=0x...

# Expiry timestamp in milliseconds (must match the oracle's configured expiry)
ORACLE_EXPIRY=1750000000000

# Strike price in DeepBook Predict units (6-decimal: $1.00 = 1000000)
ORACLE_STRIKE=1000000

# Direction: "true" = UP (price above strike at expiry), "false" = DOWN
IS_UP=true

# ── Position parameters ────────────────────────────────────────────────────────
# SUI collateral in human units (e.g. 1.5 = 1.5 SUI)
COLLATERAL_SUI=1.0

# Leverage in basis points: 11000=1.10x … 14000=1.40x
LEVERAGE_BPS=12000
